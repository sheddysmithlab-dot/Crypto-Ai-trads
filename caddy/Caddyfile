# Standalone Caddy on VPS (no Traefik). Auto-HTTPS via Let's Encrypt.
{$VPS_HOST:srv1831231.hstgr.cloud} {
	@api {
		path /health
		path /auth/*
		path /start-bot /emergency-exit /continue-trading /connect-bybit
		path /trading-mode /open-trade /manual-sell /close-trade
		path /set-pair /set-timeframe
		path /paper-trading/*
		path /agent/*
		path /settings/*
		path /system/*
		path /chart/*
		path /ws/*
	}

	handle @api {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:80
	}
}
