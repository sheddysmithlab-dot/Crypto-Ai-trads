# Auto-HTTPS for apex + www (set VPS_HOST=aitrads.in in .env on the VPS).
{$VPS_HOST:aitrads.in}, www.{$VPS_HOST:aitrads.in} {
	@api {
		path /health
		path /auth/*
		path /start-bot /emergency-exit /continue-trading /connect-bybit
		path /trading-mode /open-trade /manual-sell /close-trade
		path /set-pair /set-timeframe
		path /paper-trading/*
		path /agent/*
		path /settings/*
		path /system/*
		path /chart/*
		path /ws/*
	}

	handle @api {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:80
	}
}
