# === COPY TO backend/.env ON VPS ===
# cp .env.example .env

# --- AI (Z.ai) ---
ZAI_API_KEY=
AI_PROVIDER=z-ai
ZAI_MODEL=glm-4.5-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Dashboard login (optional) ---
AUTH_USERNAME=
AUTH_PASSWORD=

# --- Bybit TESTNET (optional — only for real testnet order execution) ---
# Market data (chart, signals, prices) uses public Bybit linear API — NO key needed.
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# --- Bybit LIVE (real account — Settings → Connect Bybit, or env here) ---
# Create at https://www.bybit.com → API Management
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_ENVIRONMENT=mainnet
# Use testnet for live wrapper on testnet: BYBIT_ENVIRONMENT=testnet

# --- Cost-aware filter (ON, moderate) ---
COST_AWARE_ENABLED=true
COST_AWARE_DRY_RUN=false
COST_AWARE_LAMBDA=1.0
COST_AWARE_MIN_CANDLE_RANGE=0.25
COST_AWARE_ABS_MIN_RANGE_PCT=0.02

# --- Fire discipline ---
MIN_PATTERN_STRENGTH=0.7
MIN_BARS_BETWEEN_AUTO_ENTRIES=3
BLOCK_OPPOSITE_AUTO_SIDE=true

# --- Whale (BTC merge, 1m poll) ---
WHALE_POLL_SECONDS=60
WHALE_MIN_BTC=100

# NOTE: Market data + signals use public Bybit linear API (no key).
# BYBIT_TESTNET_* keys are only for order execution.
