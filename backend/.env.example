# Copy to backend/.env and fill in. Never commit .env.

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false
BYBIT_ACCOUNT_TYPE=UNIFIED

# Optional overrides (defaults match main.py / trading_policy.py)
# SYMBOL=BTCUSDT
# CATEGORY=linear
# INTERVAL=1
# LEVERAGE=10
# POSITION_USDT=10
# MAX_OPEN_TRADES=3
# TAKE_PROFIT_PCT=0.8
# STOP_LOSS_PCT=0.4
# PAPER_MODE=true
# WHALE_POLL_SECONDS=60
# WHALE_MIN_BTC=100
# WHALE_ALERT_ENABLED=true

# Session schedule (Mon–Fri IST auto AI on/off). UI switch also persists to backend/data/.
# SESSION_SCHEDULE_ENABLED=false

# Hostinger website MySQL (Trading Statement). Not a VPS mysql container.
# hPanel → Databases → Remote MySQL: whitelist VPS public IP.
MYSQL_ENABLED=true
MYSQL_HOST=srv1668.hstgr.io
MYSQL_PORT=3306
MYSQL_USER=u808821982_aitrads
MYSQL_PASSWORD=
MYSQL_DATABASE=u808821982_aitrads

# Cost-aware gate (2× strict — candle gap OFF; volume 3× hard rule)
COST_AWARE_ENABLED=true
COST_AWARE_DRY_RUN=false
COST_AWARE_LAMBDA=3.0
COST_AWARE_MIN_CANDLE_RANGE=0.7
COST_AWARE_ABS_MIN_RANGE_PCT=0.06
COST_AWARE_ROUNDTRIP_COST_PCT=0.11

# Fire discipline — volume-first; no bars cooldown
MIN_PATTERN_STRENGTH=1.5
MIN_BARS_BETWEEN_AUTO_ENTRIES=0
BLOCK_OPPOSITE_AUTO_SIDE=true
VOLUME_CONFIRM_MULT=3.0
VOLUME_VS_PREV_MULT=2.0
CANDLE_TO_VOLUME_MULT=3.0
