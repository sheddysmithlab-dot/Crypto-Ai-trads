# Copy to backend/.env and fill in. Never commit .env.

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false
BYBIT_ACCOUNT_TYPE=UNIFIED

# Optional overrides (defaults match main.py / trading_policy.py)
# SYMBOL=BTCUSDT
# CATEGORY=linear
# INTERVAL=1
# LEVERAGE=10
# POSITION_USDT=10
# MAX_OPEN_TRADES=3
# TAKE_PROFIT_PCT=0.8
# STOP_LOSS_PCT=0.4
# PAPER_MODE=true
# WHALE_POLL_SECONDS=60
# WHALE_MIN_BTC=100
# WHALE_ALERT_ENABLED=true

# Cost-aware gate (mid strictness — between loose spam and hard filter)
COST_AWARE_ENABLED=true
COST_AWARE_DRY_RUN=false
COST_AWARE_LAMBDA=0.55
COST_AWARE_MIN_CANDLE_RANGE=0.15
COST_AWARE_ABS_MIN_RANGE_PCT=0.01
COST_AWARE_ROUNDTRIP_COST_PCT=0.11

# Fire discipline (mid)
MIN_PATTERN_STRENGTH=0.5
MIN_BARS_BETWEEN_AUTO_ENTRIES=0
BLOCK_OPPOSITE_AUTO_SIDE=true
