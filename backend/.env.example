# === COPY TO backend/.env ON VPS ===
# cp .env.example .env

# --- AI (Z.ai) ---
ZAI_API_KEY=
AI_PROVIDER=z-ai
ZAI_MODEL=glm-4.5-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Dashboard login (optional) ---
AUTH_USERNAME=
AUTH_PASSWORD=

# --- Bybit TESTNET (auto trade orders — paper-style execution) ---
# Create at https://testnet.bybit.com → API Management
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# --- Bybit LIVE (real account — Settings → Connect Bybit, or env here) ---
# Create at https://www.bybit.com → API Management
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_ENVIRONMENT=mainnet
# Use testnet for live wrapper on testnet: BYBIT_ENVIRONMENT=testnet

# --- TAAPI (optional — currently PAUSED; signals use Bybit klines only) ---
TAAPI_SECRET=
TAAPI_EXCHANGE=bybit
TAAPI_BATCH_DELAY_SECONDS=16

# --- Cost-aware filter ---
COST_AWARE_ENABLED=true
COST_AWARE_DRY_RUN=false
COST_AWARE_LAMBDA=2.0
COST_AWARE_MIN_CANDLE_RANGE=0.5

# NOTE: Market data (chart, signals, price feed) uses public Bybit linear API —
# no API key required for candles/tickers. Keys above are for order execution only.
