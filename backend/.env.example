# Z.ai (GLM-4.5-Flash) — permanent AI provider for this project.
# Copy this file to `.env` in the same folder and paste your key:
#   cp .env.example .env
#
# Get a key: https://z.ai (Z.AI Open Platform)
ZAI_API_KEY= 

# Optional overrides (defaults shown):
AI_PROVIDER=z-ai
ZAI_MODEL=glm-4.5-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Bybit (optional — can also be set via the Settings UI)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# BYBIT_ENVIRONMENT=mainnet

# Dashboard login (optional — server uses built-in defaults if unset)
AUTH_USERNAME=
AUTH_PASSWORD=

# TAAPI.io (candlestick-pattern gated auto-buy — get a key at https://taapi.io)
# Free plan: 1 request/15s, Bybit exchange is paid-only, so TAAPI_EXCHANGE
# defaults to "binance" as a price-correlated stand-in. Set to "bybit" once on
# a paid TAAPI plan.
TAAPI_SECRET=
TAAPI_EXCHANGE=binance
# Seconds between the two bulk pattern batches (30 patterns / 20-per-request cap).
# Default 16 respects the free plan's 1-request-per-15s limit; paid plans can use 0.
TAAPI_BATCH_DELAY_SECONDS=16

# Bybit TESTNET keys (real order execution for the TAAPI pattern policy).
# Create these at https://testnet.bybit.com — separate account/keys from your
# real Bybit account above; mainnet keys will NOT work here (Bybit rejects
# the mismatch outright).
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# Cost-aware execution filter (paper-style): λ × round-trip fee hurdle on entry; aligned exit floor.
COST_AWARE_ENABLED=true
COST_AWARE_DRY_RUN=false
COST_AWARE_LAMBDA=2.0
COST_AWARE_MIN_CANDLE_RANGE=1.0

